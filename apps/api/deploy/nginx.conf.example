# WeakSpot English Coach — Nginx reverse proxy for the FastAPI backend.
#
# Install:
#   sudo cp deploy/nginx.conf.example /etc/nginx/sites-available/weakspot-api
#   # edit server_name below to your real domain, then:
#   sudo ln -s /etc/nginx/sites-available/weakspot-api /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
#   sudo certbot --nginx -d api.your-domain.com   # adds HTTPS + redirect
#
# After certbot runs it rewrites this file to add the :443 block and an
# HTTP->HTTPS redirect automatically.

server {
    listen 80;
    server_name api.your-domain.com;

    # The diagnosis call can take 10-30s (DeepSeek). Don't cut it off.
    proxy_read_timeout 120s;
    proxy_send_timeout 120s;
    client_max_body_size 1m;

    location / {
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
