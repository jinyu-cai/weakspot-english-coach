# Copy to apps/api/.env on the production server and replace placeholders.
APP_ENV=production
APP_NAME=WeakSpot English Coach API

# Default OpenAI-compatible provider. Generic names are preferred for new
# deployments; DEEPSEEK_* is still supported for backwards compatibility.
# OPENAI_COMPAT_API_KEY=sk-REPLACE_ME
# OPENAI_COMPAT_BASE_URL=https://api.openai.com/v1
# OPENAI_COMPAT_MODEL=your_chat_model
# OPENAI_COMPAT_FAST_MODEL=your_fast_chat_model

# Alibaba Cloud Model Studio Qwen 3.7 profile. When QWEN_MODEL_STUDIO_API_KEY
# is set, it takes precedence over OPENAI_COMPAT_* and DEEPSEEK_* for the
# server default. If multiple providers have keys, the UI can safely offer each
# configured model as a server-managed choice.
# QWEN_MODEL_STUDIO_API_KEY=REPLACE_ME
# QWEN_MODEL_STUDIO_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# QWEN_MODEL_STUDIO_MODEL=qwen3.7-max
# QWEN_MODEL_STUDIO_FAST_MODEL=qwen3.7-plus
# Set an embedding-only key when the deployment should retain a different text
# provider. If omitted, embeddings reuse QWEN_MODEL_STUDIO_API_KEY.
# QWEN_EMBEDDING_API_KEY=REPLACE_ME
# QWEN_EMBEDDING_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# QWEN_EMBEDDING_MODEL=text-embedding-v4
# QWEN_EMBEDDING_DIMENSIONS=256

# Existing DeepSeek-compatible defaults
DEEPSEEK_API_KEY=<deepseek-api-key>
DEEPSEEK_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-pro
LLM_MODEL_FAST=deepseek-v4-flash

# OpenAI Realtime voice. Keep this only on the backend server.
OPENAI_API_KEY=<openai-api-key>
# Enable this only after the deployed key has GPT-5.6 access. The API refuses
# non-GPT-5.6 model IDs on this path so the demo cannot mislabel another model.
OPENAI_BUILD_WEEK_ENABLED=false
# OPENAI_BUILD_WEEK_API_KEY=<openai-api-key>
OPENAI_BUILD_WEEK_BASE_URL=https://api.openai.com/v1
OPENAI_BUILD_WEEK_MODEL=gpt-5.6-sol
OPENAI_BUILD_WEEK_REASONING_EFFORT=medium
OPENAI_BUILD_WEEK_TIMEOUT_SECONDS=180
OPENAI_REALTIME_MODEL=gpt-realtime-mini-2025-12-15
OPENAI_REALTIME_MODELS=gpt-realtime-mini-2025-12-15,gpt-realtime-2
# tts-1-hd supports a smaller voice set than newer speech models. Keep this
# model/voice pair together unless both are revalidated against the Speech API.
OPENAI_TTS_BASE_URL=https://api.openai.com/v1
OPENAI_TTS_MODEL=tts-1-hd
OPENAI_TTS_VOICE=nova

# AWS DynamoDB
AWS_REGION=us-east-1
# Prefer an EC2 IAM role when deploying on EC2. If using an IAM role, omit
# AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY from the real .env file.
AWS_ACCESS_KEY_ID=REPLACE_ME
AWS_SECRET_ACCESS_KEY=REPLACE_ME
DYNAMODB_TABLE=WeakSpotEnglishCoach

# Comma-separated list of exact frontend origins.
CORS_ORIGINS=https://your-vercel-app.vercel.app,https://your-custom-domain.com
DEMO_USER_ID=demo-user-001

# MemoryAgent
MEMORY_ENABLED=true
MEMORY_CONTEXT_TOKEN_BUDGET=700
MEMORY_CONTEXT_TOKEN_SAFETY_RATIO=0.85
MEMORY_RETRIEVAL_LIMIT=6
MEMORY_MAX_ITEMS_PER_USER=200
MEMORY_CHAT_RECENT_MESSAGES=12

# Auth (GitHub OAuth) + rate limiting
GITHUB_CLIENT_ID=REPLACE_ME
GITHUB_CLIENT_SECRET=REPLACE_ME
SESSION_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET
OAUTH_REDIRECT_URI=https://api.your-domain.com/api/v1/auth/github/callback
FRONTEND_URL=https://your-vercel-app.vercel.app
COOKIE_DOMAIN=.your-domain.com
OWNER_GITHUB_LOGINS=your-github-login,test-github-login
# OWNER_BYPASS_TOKEN=
GUEST_DAILY_LIMIT=3
USER_DAILY_LIMIT=20

# Production: keep local testing settings unset.
# DYNAMODB_ENDPOINT_URL=
# USE_FAKE_AI=false
