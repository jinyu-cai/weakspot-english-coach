# Copy this file to .env and fill in real values. Never commit .env.
APP_ENV=development
APP_NAME=WeakSpot English Coach API

# Default OpenAI-compatible provider.
# Generic names are preferred for new deployments; DEEPSEEK_* is still supported
# for backwards compatibility with the original deployment.
# OPENAI_COMPAT_API_KEY=your_provider_key
# OPENAI_COMPAT_BASE_URL=https://api.openai.com/v1
# OPENAI_COMPAT_MODEL=your_chat_model
# OPENAI_COMPAT_FAST_MODEL=your_fast_chat_model

# Alibaba Cloud Model Studio Qwen 3.7 profile. When QWEN_MODEL_STUDIO_API_KEY
# is set, it takes precedence over OPENAI_COMPAT_* and DEEPSEEK_* for the
# server default. If multiple providers have keys, the UI can safely offer each
# configured model as a server-managed choice.
# QWEN_MODEL_STUDIO_API_KEY=your_model_studio_api_key
# QWEN_MODEL_STUDIO_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# QWEN_MODEL_STUDIO_MODEL=qwen3.7-max
# QWEN_MODEL_STUDIO_FAST_MODEL=qwen3.7-plus
# Embedding-only deployments can set these without changing the default text
# provider (for example, Oracle can stay on DeepSeek).
# QWEN_EMBEDDING_API_KEY=your_model_studio_api_key
# QWEN_EMBEDDING_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# QWEN_EMBEDDING_MODEL=text-embedding-v4
# QWEN_EMBEDDING_DIMENSIONS=256

# Existing DeepSeek-compatible defaults
DEEPSEEK_API_KEY=your_deepseek_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-pro
LLM_MODEL_FAST=deepseek-v4-flash

# OpenAI Realtime voice. This key stays server-side and is exchanged for
# short-lived browser client secrets by /api/v1/chat/realtime/session.
OPENAI_API_KEY=your_openai_key
OPENAI_REALTIME_MODEL=gpt-realtime-mini-2025-12-15
OPENAI_REALTIME_MODELS=gpt-realtime-mini-2025-12-15,gpt-realtime-2
# Coach listening playback uses the same server-side OpenAI key by default.
# tts-1-hd is the quality-oriented Speech API model; the browser falls back to
# local Web Speech when this key/model is unavailable.
OPENAI_TTS_BASE_URL=https://api.openai.com/v1
OPENAI_TTS_MODEL=tts-1-hd
OPENAI_TTS_VOICE=nova

# AWS DynamoDB
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
DYNAMODB_TABLE=WeakSpotEnglishCoach

# CORS: comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000,https://your-vercel-app.vercel.app
DEMO_USER_ID=demo-user-001

# MemoryAgent: bounded cross-session context, hybrid retrieval, and forgetting.
MEMORY_ENABLED=true
MEMORY_CONTEXT_TOKEN_BUDGET=700
# Build against 85% of the requested ceiling because token counts are a
# conservative estimate rather than the private Qwen production tokenizer.
MEMORY_CONTEXT_TOKEN_SAFETY_RATIO=0.85
MEMORY_RETRIEVAL_LIMIT=6
MEMORY_MAX_ITEMS_PER_USER=200
MEMORY_CHAT_RECENT_MESSAGES=12

# Auth (GitHub OAuth) + rate limiting
# GITHUB_CLIENT_ID=your_github_oauth_client_id
# GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
# SESSION_SECRET=replace_with_a_long_random_string
# OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/github/callback
# FRONTEND_URL=http://localhost:3000
# COOKIE_DOMAIN=
# OWNER_GITHUB_LOGINS=your-github-login,test-github-login
# OWNER_BYPASS_TOKEN=
GUEST_DAILY_LIMIT=3
USER_DAILY_LIMIT=20

# ---- Local testing (optional) ----
# Use a local DynamoDB emulator instead of AWS
# (docker compose -f docker-compose.local.yml up -d):
# DYNAMODB_ENDPOINT_URL=http://localhost:8001
# For the emulator, any dummy creds work: AWS_ACCESS_KEY_ID=local / AWS_SECRET_ACCESS_KEY=local
# Skip DeepSeek and return canned AI results (no key needed):
# USE_FAKE_AI=false
# Log a short invalid model-output preview when JSON validation fails.
# Keep false unless you are debugging because previews can contain user text.
# LLM_DEBUG_LOG_CONTENT=false
