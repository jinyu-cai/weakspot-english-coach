# Copy this file to .env and fill the secret locally. Never commit or paste it.
DASHSCOPE_API_KEY=replace_with_your_qwen_cloud_api_key

# Qwen Cloud Singapore / international endpoint used by this project.
DASHSCOPE_WEBSOCKET_BASE_URL=wss://dashscope-intl.aliyuncs.com/api-ws/v1/inference

QWEN_TTS_MODEL=qwen-audio-3.0-tts-plus
QWEN_TTS_VOICE=longanlingxin
QWEN_TTS_LANGUAGE=en
QWEN_TTS_SPEECH_RATE=1.0
QWEN_TTS_INSTRUCTION=Natural US English, warm and confident, clear technical terms, subtle pauses.
